# THE 6th ESTATE — environment template.
# Copy to `.env` and fill in as needed. NEVER commit a real `.env`.
# All values are OPTIONAL: with none set, the system runs fully offline in
# demo/dry-run mode (no network, no publishing, no email). Every figure below is
# a PLANNING ASSUMPTION — verify current provider terms, quotas, and pricing.

# ── Brand / canonical domain ─────────────────────────────────────────────────
SIXTHE_CANONICAL_DOMAIN=the6thestate.net

# ── Automation posture (KEEP DISABLED unless you intend to publish/send) ──────
# Master switch for automated publishing. Default false.
SIXTHE_AUTOMATION_ENABLED=false
# Minimum validated items required to auto-publish. Default 14 (the full edition).
SIXTHE_PUBLICATION_FLOOR=14

# ── Discovery: RSS-first ($0), bounded fallbacks ─────────────────────────────
# Comma-separated feed URLs. Leave unset to use documented public defaults.
# You are responsible for confirming each feed is permitted for reuse.
SIXTHE_RSS_FEEDS=

# Brave Search — paid fallback used ONLY to fill missing sections, capped/day.
SIXTHE_BRAVE_ENABLED=false
BRAVE_API_KEY=
SIXTHE_BRAVE_DAILY_CAP=10
BRAVE_API_BASE=https://api.search.brave.com/res/v1/web/search

# Google Programmable Search — optional backup, DISABLED by default.
SIXTHE_GOOGLE_PSE_ENABLED=false
GOOGLE_PSE_KEY=
GOOGLE_PSE_CX=
GOOGLE_PSE_BASE=https://www.googleapis.com/customsearch/v1

# (SearXNG is documented as a future option only; not implemented.)

# ── Data-box public APIs ─────────────────────────────────────────────────────
FRED_API_KEY=
FRED_API_BASE=https://api.stlouisfed.org/fred
BLS_API_KEY=
BLS_API_BASE=https://api.bls.gov/publicAPI/v2
COINGECKO_API_BASE=https://api.coingecko.com/api/v3
WEATHER_API_BASE=https://api.weather.gov
WIKIPEDIA_API_BASE=https://api.wikimedia.org/feed/v1/wikipedia/en/onthisday
# Sports: leave provider empty to keep scores disabled. Confirm permitted use
# before enabling; prefer official league feeds over scraping.
SIXTHE_SPORTS_PROVIDER=
SPORTS_API_BASE=

# ── Model configuration (Gemini) ─────────────────────────────────────────────
# Model IDs are configurable so deprecated versions swap without code edits.
# VERIFY availability and pricing with the provider before relying on these.
GEMINI_API_KEY=
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL_BRIEFINGS=gemini-2.5-flash
GEMINI_MODEL_QUICK_HITS=gemini-2.5-flash-lite
GEMINI_TEMPERATURE=0.2
# Hard ceiling on model calls per edition (one batched pass + one fallback).
SIXTHE_MODEL_CALL_LIMIT=2

# ── Brevo email (sending is TRIPLE-gated: --send flag + this flag + credential)
SIXTHE_EMAIL_ENABLED=false
BREVO_API_KEY=
BREVO_API_BASE=https://api.brevo.com/v3
BREVO_LIST_ID=11
BREVO_SENDER_NAME=The 6th Estate
BREVO_SENDER_EMAIL=news@the6thestate.net
BREVO_REPLY_TO=editor@the6thestate.net
